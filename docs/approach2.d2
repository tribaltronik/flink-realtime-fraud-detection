# Approach 2: Apache Flink Cluster

generator: Transaction Generator {
  style.fill: "#e8f4ff"
}

kafka_in: Kafka {
  style.fill: "#fff8e1"
}

flink_cluster: Flink Cluster {
  style.fill: "#f3e5f5"
}

jm: JobManager {
  style.fill: "#e1bee7"
}

tm: TaskManager {
  style.fill: "#e1bee7"
}

flink_ui: Flink UI {
  style.fill: "#e3f2fd"
}

kafka_out: Kafka Topic {
  style.fill: "#fce4ec"
}

generator -> kafka_in
kafka_in -> flink_cluster
flink_cluster -> kafka_out
jm -> tm
